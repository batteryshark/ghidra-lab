# Match this to the Ghidra version your GUI clients run — a shared project's
# program data uses version-specific language definitions, so an older headless
# agent cannot open programs a newer GUI created.
GHIDRA_VERSION=12.1.2
GHIDRA_DATE=20260605
GHIDRA_MCP_REF=378f727b7059163eb6ba3ae315c4d9233decba66

# MCP bearer token. Generate a real one before exposing on Tailscale:
#   openssl rand -hex 32
GHIDRA_LAB_TOKEN=change-me-generate-a-real-token

# Addressing. For a real deployment, set these to this host's Tailscale IPv4 so
# the server's TLS cert advertises an address both the lab container and your
# desktop GUI can reach. For a self-contained local test, use the in-compose
# name instead: GHIDRA_LAB_BIND=127.0.0.1 and *_HOST=ghidra-server.
GHIDRA_LAB_BIND=100.64.0.1
GHIDRA_SERVER_PUBLIC_HOST=100.64.0.1
GHIDRA_SERVER_ALT_NAMES=100.64.0.1;ghidra-server
GHIDRA_SERVER_MAX_MEMORY_MB=2048

# Public URL returned by the lab_sample_* upload/download tools. Behind Tailscale
# Serve this is http://<tailscale-ip>:8081; for a local test it is the published
# host port, http://127.0.0.1:18080.
GHIDRA_LAB_PUBLIC_BASE_URL=http://100.64.0.1:8081
GHIDRA_LAB_LOCAL_PORT=18080

GHIDRA_LAB_SEARCH_RESULTS=8
GHIDRA_LAB_MAX_UPLOAD_BYTES=4294967296
JAVA_OPTS=-Xmx6g -XX:+UseG1GC

# Agent service account. The ghidra-server container auto-creates this user from
# the password in ./.ghidra-agent-password (mounted as a secret). If automatic
# creation ever fails, make it once by hand:
#   docker compose exec ghidra-server /opt/ghidra/server/svrAdmin -add agent --p
GHIDRA_AGENT_SERVER_HOST=100.64.0.1
GHIDRA_AGENT_SERVER_PORT=13100
GHIDRA_AGENT_SERVER_USER=agent

# Repository the agent imports into and the shared project binds to.
GHIDRA_LAB_DEFAULT_REPOSITORY=GhidraLab
# Existing human server accounts to grant access on that repository (semicolon
# separated), e.g. your GUI login. Leave empty if none exist yet.
GHIDRA_LAB_REPO_USERS=admin

GHIDRA_LAB_ANALYZE_HEADLESS_TIMEOUT=1800
GHIDRA_LAB_ANALYSIS_TIMEOUT_PER_FILE=0
